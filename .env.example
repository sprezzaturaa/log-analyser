# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed as a template.

# Required for /api/ai-summary. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional. Comma-separated origins allowed to call the API.
# Default if unset: http://localhost:5173,http://127.0.0.1:5173
# Use "*" only for local dev — never in production.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional. Per-IP rate limit for /api/ai-summary, requests per minute.
# Default: 5
AI_RATE_PER_MIN=5

# Optional. Per-IP rate limit for /api/analyze, requests per minute.
# Default: 30
ANALYZE_RATE_PER_MIN=30

# Optional. Bind address. Default: 127.0.0.1:8080
BIND_ADDR=127.0.0.1:8080

# Optional. When running behind a trusted reverse proxy (Fly, Cloudflare, nginx),
# set this to 1 so the rate limiter reads X-Forwarded-For instead of the TCP peer.
# Leave OFF on direct binds — the header is spoofable.
TRUST_PROXY=0
